{
  "name": "management-system-express-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "pnpm run prisma:migrate:dev && tsx watch src/app.ts",
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "start": "node dist/app.js",
    "prisma:migrate:prod": "prisma migrate && prisma generate",
    "prisma:migrate:test": "dotenv -e .env.test -- pnpm exec prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate deploy",
    "test": "pnpm run prisma:migrate:test && vitest run",
    "test:watch": "pnpm run prisma:migrate:test && vitest",
    "test:coverage": "pnpm run prisma:migrate:test && vitest run --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.1.3",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "prisma": "^7.8.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "joi": "^18.2.3",
    "zod": "^4.4.3"
  }
}